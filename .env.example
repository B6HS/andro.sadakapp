# Production sous-domaine (build Vercel) : base à la racine
# VITE_BASE_PATH=/
# VITE_PRODUCT_LABEL=andro.sadak.app
# VITE_PRODUCT_HOST=andro.sadak.app
# Optionnel si besoin d’URL fixe (emails, liens) :
# VITE_PRODUCT_ORIGIN=https://andro.sadak.app

# Développement local (défaut si non défini) : /android/
# VITE_BASE_PATH=/android/

# Script scripts/add-supabase-redirect-urls.mjs (ne pas committer le token) :
# SUPABASE_ACCESS_TOKEN=sbp_...
